# camp-server configuration. Copy to `.env` and edit — this file is the ONLY
# thing that differs between deploy targets (3090 box vs V100 VM).

# Server-only secret that SIGNS the session cookies (app/auth.py). This no
# longer ships to clients — it must be a strong random value, and the SAME value
# on every replica (they share this .env) so a cookie one replica mints verifies
# on any other behind the LB. Generate one:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
CAMP_TOKEN=change-me

# Per-person auth (app/roster.py). Students log in with their roster name +
# birthday; STAFF log in with their own display name + this shared password.
# Never ships in the bundle. Rotate if it leaks (README → "Rotating passwords").
STAFF_PASSWORD=change-me

# Password for the fixed `admin` username — unlocks GET /admin/usage (box-wide
# per-person usage aggregate + live ban/throttle state).
ADMIN_PASSWORD=change-me

# Shared password for 隊輔 accounts. Usernames come from the groups CSV's 隊輔
# column (app/groups.py); they log in as role "mentor" and rank on the quest
# leaderboard under their own 小隊, so the quest flow is testable end to end.
# Leave unset (or "change-me") to disable 隊輔 login entirely.
#MENTOR_PASSWORD=

# Roster CSV of `名字,YYYY-MM-DD` rows. Names are login usernames, birthdays
# are the passwords (8 digits, separators forgiven). PII: keep the file OUTSIDE
# the repo (mode 600); students-bd.csv is gitignored as a safety net only.
# Default resolves to <repo>/students-bd.csv — point this somewhere private.
#STUDENTS_CSV=/home/<user>/camp-private/students-bd.csv

# 小隊 mapping CSV for the quest leaderboard (app/groups.py). Paste the real
# camp sheet onto the box by hand (it is PII and never committed); ONLY the
# 姓名 and 組別 columns are read — 隊輔/房號/衣服size/… are ignored and never
# logged or exposed. Missing/malformed file → the server still boots and every
# student ranks under 未分組 until the file lands (then restart). Shape:
# student-group-id.example.csv in the repo root.
# Default resolves to <repo>/student-group-id.csv.
#GROUPS_CSV=/home/<user>/camp-private/student-group-id.csv

# Where per-replica usage-<port>.jsonl logs, quests-<port>.jsonl attempt logs
# + controls.json (ban/throttle state written by scripts/usagetui.py) live.
# Default <repo>/server/usage (gitignored).
#USAGE_DIR=

# Session cookie lifetime in hours. Short by design — a session is a convenience
# for the class period, not a long-lived credential. Default 8 (a camp day).
#SESSION_TTL_HOURS=8

# Cookie security. Default 1 → Secure + SameSite=None, required for the https
# cross-origin (page ↔ funnel) production setup. Set to 0 ONLY for same-site
# http localhost dev (→ SameSite=Lax, no Secure). Never 0 in production.
#COOKIE_SECURE=1

# Comma-separated list of browser origins allowed by CORS. No wildcard.
# Include the deployed course2 origin plus local dev. (CORS runs with
# allow_credentials=True so the session cookie rides along — hence no '*'.)
ALLOWED_ORIGINS=http://localhost:5173

# Port uvicorn listens on (single-process deploy: 3090/dev box; the systemd
# unit and scripts/serve.sh read this).
PORT=8300

# --- multi-GPU deploy (V100 box) --------------------------------------------
# Running one replica per GPU behind the caddy LB (server/deploy/) is a DEPLOY
# choice, not a code mode: the app stays single-device; each replica is pinned
# via CUDA_VISIBLE_DEVICES and sees its card as cuda:0. The tailscale funnels
# are unaffected — the proxy simply takes over the port the backend funnel
# already targets. Defaults below are what serve-multi.sh / camp-server@.service
# / the Caddyfile assume; uncomment only to override.
# Backends bind 127.0.0.1:(BASE_PORT+1+gpu_index) → 8301..8304.
#BASE_PORT=8300
# Port the load-balancing proxy listens on (= the backend funnel's target).
#PROXY_PORT=8300

# Torch device: auto → cuda:0 if available, else mps, else cpu.
# Explicit overrides: cuda:0 / mps / cpu. NEVER hardcode a device in code.
DEVICE=auto

# --- abuse guards (see app/limits.py) ---------------------------------------
# The routes are behind per-person credentials → session cookie, but any valid
# session can still call the GPU, so these bound the blast radius. Inference
# buckets key on the session USERNAME (one student throttling does not slow the
# rest); staff can also ban/throttle one person live from the usage TUI. ALL
# are PER PROCESS — under the 4-replica serve-multi deploy the box-wide ceiling
# is ~4× these. Leave unset to use the defaults shown.

# Hard cap on simultaneous GPU-path requests per process. This is the REAL GPU
# protection (source-independent: a flood of any origin can't exceed it), so
# lower it if you want a tighter ceiling. Default 6.
#MAX_CONCURRENT_INFER=6
# Extra requests allowed to WAIT for a slot before returning 429 (the frontend
# treats 429 as "offline" and falls back to precomputed JSON). Default 12.
#INFER_QUEUE=12

# Forgiving last-resort rate limit (token bucket per person on the inference
# routes; per-IP/global on /auth) — kept generous on purpose so it never bites
# a real ~40-student class; the concurrency cap above is what actually guards
# the GPU.
# Set RATE_LIMIT_PER_MIN=0 to disable the rate limit entirely.
#RATE_LIMIT_PER_MIN=600
#RATE_LIMIT_BURST=120
# Peers whose X-Forwarded-For is trusted to name the real client (the local
# Caddy/funnel hop). Default covers loopback. Never add an arbitrary/public IP.
#TRUSTED_PROXIES=127.0.0.1,::1

# Expose /docs, /redoc, /openapi.json AND the detailed /health body (exact card
# name + loaded models). OFF in production; set to 1 only for local API
# browsing. Default off.
#ENABLE_DOCS=0

# Where `camp-precompute export-embedding-state` wrote the npz state files.
# Default resolves to <repo>/precompute/artifacts — only set to override.
#WEIGHTS_DIR=

# Where the shipped course2 JSON artifacts live (in-vocab lookups are answered
# straight from these, guaranteeing live == precomputed). Default resolves to
# <repo>/apps/course2/public/data/course2 — only set to override.
#DATA_DIR=

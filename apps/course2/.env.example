# Course 2 station env. Copy to `.env.local` (gitignored) and edit.

# Live inference server (server/ — see server/README.md). OPT-IN: when unset,
# every station uses precomputed JSON exactly as before. When set, the
# embedding / next-token / rnn-viz / transformer stations send CUSTOM student
# input to the server (same models as precompute) and fall back to precomputed
# data whenever the server is unreachable.
#VITE_LIVE_INFERENCE_URL=http://localhost:8300
#VITE_LIVE_INFERENCE_TOKEN=<the server's CAMP_TOKEN>

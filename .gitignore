# dependencies
node_modules
.pnpm-store

# build output
dist
.next

build
*.tsbuildinfo

# turbo
.turbo

# python / uv
.venv
__pycache__
*.pyc
.ruff_cache

# precompute heavy artifacts (small JSON manifests ARE committed; large binaries are NOT)
public/data/**/*.onnx
public/data/**/*.bin
# diffusion station denoising-trajectory frames: the REAL SD-Turbo bake writes
# many webp frames (large). Only the small presets.json is committed by default;
# the tiny hand-off SAMPLE frames are force-added once (`git add -f`) so a fresh
# checkout renders offline (see prompts/server-runs/diffusion-precompute.md).
public/data/**/diffusion/**/*.webp
# skyfall station splat scenes: binaries, gitignored by pattern so a careless
# unpruned bake can't land by accident. The final pruned set (~26 MB per after
# scene at the default 800 k splats, ≤ 80 MB total) is committed deliberately
# with `git add -f` (see prompts/server-runs/skyfall-precompute.md). Source
# PLYs (158-324 MB) stay in precompute/artifacts/skyfall/ — never committed.
public/data/**/skyfall/**/*.splat
# text-to-3d station TRELLIS objects: binaries, gitignored by pattern so an
# unpruned bake can't land by accident. The final pruned set (≤ ~2 MB per
# object, ≤ 60 MB total for ~16 prompts × 2 seeds) + tiny picker thumbnails are
# committed deliberately with `git add -f` (see prompts/server-runs/trellis-
# precompute.md). Exported PLYs stay in the gitignored _ply_cache — never
# committed. NOTE: the leading `**/` is load-bearing — the data lives under
# apps/course2/public/data/, so a root-anchored `public/data/**` (as the skyfall
# / diffusion lines above are written) would NOT actually match it. `**/` lets
# the pattern bite regardless of the app prefix.
# pixel-shuffle station CIFAR pack: a ~6 MB binary, ignored by pattern so a
# re-bake can't land by accident; the shipped pack is committed deliberately
# with `git add -f` so a fresh checkout runs the classroom offline. The `**/`
# prefix is load-bearing (see the text-to-3d note below).
**/public/data/**/pixel-shuffle/*.gz
**/public/data/**/text-to-3d/**/*.splat
**/public/data/**/text-to-3d/**/*.webp
**/public/data/**/text-to-3d/_ply_cache/

# live-server model state (npz written by `camp-precompute export-embedding-state`;
# regenerable, ~10 MB/language — never committed)
precompute/artifacts/

# student roster (names + birthdays = PII, and the birthdays are the login
# passwords). The real file lives OUTSIDE the repo (see STUDENTS_CSV in
# server/.env); this pattern is a safety net so a stray copy can't land.
students-bd.csv
# 小隊 mapping for the quest leaderboard (names + camp logistics = PII). The
# real file is pasted onto the box by hand (see GROUPS_CSV in server/.env);
# only student-group-id.example.csv (fake names) is committed.
student-group-id.csv
# per-person usage logs + ban/throttle state + quest attempt logs (runtime
# state written by server/app/usage.py, scripts/usagetui.py and
# server/app/quests/storage.py)
server/usage/

# classroom progression lock — runtime state written by scripts/unlock.sh
apps/course2/public/unlocked.txt
# classroom live control (lock / goto broadcasts) — written by scripts/classroom.mjs
apps/course2/public/classroom.json

# editor / os
.DS_Store
*.log
.env
.env.local
.env*.local
.vscode/*
!.vscode/extensions.json

# Claude Code local scratch (worktrees, local settings) — never committed
.claude/
slides/reference
slides/decks/png

# Affinity source files (large binaries; export PNG/PDF for the repo instead)
*.af
*.af~lock~
# Cloned reference apps for planning (not ours; MIT — see LICENSE inside)
.reference/

# Puppeteer/headless-Chrome binary downloaded for in-browser diagnosis (261M) — never committed
chrome-headless-shell/
